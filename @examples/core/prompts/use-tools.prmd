---
id: use-tools
name: "Use Tools"
version: 0.0.1
description: "Acts as a base prompt that allows passing tool call instructions."
parameters:
- name: tools
  type: json
  description: "List of tools with name and description"
  required: true
  default:
  - name: edit_file
    description: "Edit an existing file by replacing a specific string with new content"
    parameters:
      - name: file_path
        type: string
        description: "Path to the file to edit"
        required: true
      - name: old_string
        type: string
        description: "The exact string to find and replace"
        required: true
      - name: new_string
        type: string
        description: "The replacement string"
        required: true
  - name: write_file
    description: "Create or overwrite a file with the given content"
    parameters:
      - name: file_path
        type: string
        description: "Path to the file to create or overwrite"
        required: true
      - name: content
        type: string
        description: "The full file content to write"
        required: true
  - name: get_document_errors
    description: "Get validation errors and warnings for the current document"
    parameters: []
- name: schema
  type: json
  description: "Tool call schema defining the XML format for tool invocations"
  required: false
  default: >-
    {"call": "<tool_call><tool>[[tool]]</tool><params>[[params]]</params></tool_call>"}
- name: override_output
  type: string
  description: "Optional override for the output format instructions"
  required: false
- name: enable_tools
  type: boolean
  default: false
  description: "Shows the tools when enabled and skips then if not."
---
{% if enable_tools %}

{% include "../snippets/parameter-list-view.prmd" %}

{% endif %}

{% if override_output %}

## Output Format

{{ override_output }}

{% endif %}