{
  "version": "1.0.0",
  "metadata": {
    "id": "topic-research-workflow",
    "name": "Topic Research Workflow",
    "description": "A simple workflow that takes a topic, sends it to an LLM for research, and outputs the result."
  },
  "parameters": [
    {
      "name": "topic",
      "type": "string",
      "required": true,
      "description": "The topic to research"
    }
  ],
  "nodes": [
    {
      "id": "trigger-1",
      "type": "trigger",
      "position": {
        "x": 150,
        "y": 300
      },
      "data": {
        "label": "Start",
        "triggerType": "manual"
      }
    },
    {
      "id": "prompt-1",
      "type": "prompt",
      "position": {
        "x": 450,
        "y": 300
      },
      "data": {
        "label": "Research Topic",
        "source": "./prompts/topic-researcher.prmd",
        "provider": "openai",
        "model": "gpt-4o",
        "parameters": {
          "topic": "{{ workflow.topic }}"
        },
        "sourceType": "file",
        "errorHandlerNodeId": "error-handler-1773178013540"
      }
    },
    {
      "id": "output-1",
      "type": "output",
      "position": {
        "x": 750,
        "y": 300
      },
      "data": {
        "label": "Output"
      }
    },
    {
      "id": "callback-1773177976633",
      "type": "callback",
      "position": {
        "x": 480,
        "y": 360
      },
      "data": {
        "label": "Research Checkpoint",
        "mode": "report",
        "checkpointName": "Research Checkpoint",
        "includePreviousOutput": true,
        "includeNextNodeInfo": true,
        "waitForAck": false,
        "_preDockPosition": {
          "x": 480,
          "y": 360
        },
        "dockedTo": {
          "nodeId": "prompt-1",
          "handleId": "onCheckpoint"
        },
        "logToHistory": true,
        "logToConsole": true,
        "promptCaptureCompiled": true,
        "promptCaptureTokens": true
      }
    },
    {
      "id": "error-handler-1773178013540",
      "type": "error-handler",
      "position": {
        "x": 345,
        "y": 45
      },
      "data": {
        "label": "Error Handler",
        "strategy": "rethrow",
        "retry": {
          "maxAttempts": 3,
          "backoffMs": 1000,
          "backoffMultiplier": 2
        }
      }
    }
  ],
  "edges": [
    {
      "id": "e-trigger-prompt",
      "source": "trigger-1",
      "target": "prompt-1",
      "sourceHandle": "output",
      "targetHandle": "input",
      "animated": false
    },
    {
      "id": "e-prompt-output",
      "source": "prompt-1",
      "target": "output-1",
      "sourceHandle": "output",
      "targetHandle": "input",
      "animated": false
    },
    {
      "id": "docked-callback-1773177976633-prompt-1-onCheckpoint",
      "source": "prompt-1",
      "target": "callback-1773177976633",
      "sourceHandle": "onCheckpoint",
      "targetHandle": "input"
    }
  ]
}